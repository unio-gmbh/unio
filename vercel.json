{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/ui_kits/homepage/index.html", "destination": "/", "permanent": true },
    { "source": "/ui_kits/homepage/:page.html", "destination": "/:page", "permanent": true },
    { "source": "/ui_kits/homepage/:page", "destination": "/:page", "permanent": true },
    { "source": "/ui_kits/:path*", "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ]
}
